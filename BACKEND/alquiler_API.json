				{
					"name": "A. Registrar Usuario (Paco)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nombre\": \"Paco Nuevo\",\n    \"dni\": \"12345678X\",\n    \"email\": \"paco@nuevo.com\",\n    \"telefono\": \"+34600112233\",\n    \"password\": \"mi_password_segura\",\n    \"confirmPassword\": \"mi_password_segura\",\n    \"tipoUsuario\": \"PROPIETARIO\"\n}"
						},
						"url": {
							"raw": "http://localhost:8092/api/auth/register",
							"host": [
								"localhost"
							],
							"port": "8092",
							"path": [
								"api",
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "B. Login (¡Guarda el token automático!)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.token) {",
									"    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
									"    console.log(\"¡Token guardado con éxito!\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"paco@nuevo.com\",\n    \"password\": \"mi_password_segura\"\n}"
						},
						"url": {
							"raw": "http://localhost:8092/api/auth/login",
							"host": [
								"localhost"
							],
							"port": "8092",
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					},
					"response": []
				},
